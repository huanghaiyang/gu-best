{
  "name": "gu-best-stock-platform",
  "version": "1.0.0",
  "description": "股票分析平台 - Python后端 + Vue前端",
  "scripts": {
    "dev": "npm run db:check && concurrently \"npm run python:dev\" \"npm run client:dev\"",
    "python:dev": "python app.py",
    "python:prod": "npm run db:check && python app.py",
    "client:dev": "vite",
    "client:build": "vite build",
    "client:preview": "vite preview",
    "build": "npm run client:build",
    "start": "npm run python:prod",
    "lint": "eslint . --ext .js,.vue",
    "lint:fix": "eslint . --ext .js,.vue --fix",
    "db:clear": "python scripts/db_manage.py clear",
    "db:init": "python scripts/db_manage.py init",
    "db:reset": "python scripts/db_manage.py reset",
    "db:dump": "python scripts/db_manage.py dump",
    "db:check": "python scripts/db_manage.py check",
    "test": "npm run db:check && python test/run_tests.py",
    "test:dev": "concurrently \"npm run python:dev\" \"sleep 3 && python test/run_tests.py\""
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.5.2",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.19.2",
    "vite": "^5.0.8",
    "vue": "^3.3.11"
  },
  "keywords": [
    "stock",
    "analysis",
    "trading",
    "vue",
    "python"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "lodash": "^4.17.23"
  }
}
