{
  "name": "gu-best-stock-platform",
  "version": "1.0.0",
  "description": "股票分析平台 - Python后端 + Vue前端",
  "scripts": {
    "dev": "concurrently \"npm run python:dev\" \"npm run client:dev\"",
    "python:dev": "python app.py",
    "python:prod": "python app.py",
    "client:dev": "vite",
    "client:build": "vite build",
    "client:preview": "vite preview",
    "build": "npm run client:build",
    "start": "npm run python:prod",
    "lint": "eslint . --ext .js,.vue",
    "lint:fix": "eslint . --ext .js,.vue --fix"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^4.5.2",
    "concurrently": "^8.2.2",
    "eslint": "^8.56.0",
    "eslint-plugin-vue": "^9.19.2",
    "vite": "^5.0.8",
    "vue": "^3.3.11"
  },
  "keywords": [
    "stock",
    "analysis",
    "trading",
    "vue",
    "python"
  ],
  "author": "",
  "license": "MIT"
}
